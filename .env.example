# 1. Create the placeholder file
cat <<EOF > .env.example
MYSQL_ROOT_PASSWORD=01190
MYSQL_DB=sakila
MYSQL_USER=root
MYSQL_PASSWORD=01190
EOF

# 2. Create the actual file your containers will use
cat <<EOF > .env
MYSQL_ROOT_PASSWORD=admin
MYSQL_DB=sakila
MYSQL_USER=root
MYSQL_PASSWORD=admin
EOF

# 3. Add .env to .gitignore so it never gets uploaded
echo ".env" >> .gitignore